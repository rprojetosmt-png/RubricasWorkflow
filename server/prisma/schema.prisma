generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Solicitacao {
  id              String   @id
  codigo          String
  titulo          String
  tipo            String
  solicitante     Json
  dataSolicitacao DateTime
  statusGeral     String
  etapaAtual      String
  descricao       String
  documentos      Json?
  historico       Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
